# OpenAI API Key
OPENAI_API_KEY=OPEN_API_KEY

# SQL Server connection string (SQLAlchemy + pyodbc format)
DB_CONNECTION_STRING=mssql+pyodbc://USER:PWD@HOSTNAME\SQL_SERVER_NAME/DB_NAME?driver=ODBC+Driver+17+for+SQL+Server

# Path to salary PDF (relative to project root)
PDF_PATH=resources/company_salaries.pdf

# Set to true to enable LangSmith tracing (requires LANGCHAIN_API_KEY)
LANGSMITH_TRACING=false

# LLM provider: "openai" (default) or "azure"
LLM_PROVIDER=openai

# Azure OpenAI (required when LLM_PROVIDER=azure)
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-02-01
Provider=SQLOLEDB.1;Password=sa-123456;Persist Security Info=True;User ID=saa;Initial Catalog=company_demo;Data Source=yc-sqlserver-01.database.windows.net
